(*
The EBNF specifying the grammar of EnlightenedC.
Translated from the Bison grammar in src/frontend/parser.yy.

Notation:
  { x }   — zero or more repetitions of x
  [ x ]   — x is optional
  x+      — one or more repetitions of x (regex-style shorthand for x { x })
  x | y   — alternation
  "x"     — terminal token
*)

(* PROGRAM: *)

program = program-item*

program-item = function-definition
             | declaration
             | statement

(* FUNCTION DEFINITIONS: *)

function-definition = declaration-specifier-list declarator compound-statement

(* DECLARATIONS: *)

declaration = declaration-specifier-list ";"
            | declaration-specifier-list init-declarator-list ";"

declaration-specifier-list = type-specifier
                            | storage-class-specifier declaration-specifier-list
                            | type-qualifier declaration-specifier-list

storage-class-specifier = "public"
                        | "static"
                        | "extern"
                        | "extern" string-literal       (* extern "C" linkage *)

type-specifier = "void"
               | primitive-type
               | type-identifier
               | class-specifier
               | union-specifier
               | enum-specifier

primitive-type = "U8i" | "U16i" | "U32i" | "U64i"
               | "I8i" | "I16i" | "I32i" | "I64i"
               | "F32i" | "F64i"
               | "Bool"

type-qualifier = "const"

type-qualifier-list = type-qualifier+

(*
  A type-identifier is an ordinary identifier that has been previously declared
  as a type name. The lexer distinguishes these from plain identifiers (lexer hack).
*)
type-identifier = TYPEDEF_NAME

(* CLASS SPECIFIERS: *)

class-specifier = "class" identifier ":" class-parent-list "{" member-declaration-list "}"
                | "class" identifier "{" member-declaration-list "}"
                | "class" "{" member-declaration-list "}"
                | "class" identifier

class-parent-list = class-parent { "," class-parent }

class-parent = [ "class" ] identifier

(* UNION SPECIFIERS: *)

(*
  The primitive-type prefix specifies a type representative for the union.
  It is only permitted when a body follows; "primitive-type union name" without
  braces is a syntax error.
*)
union-specifier = [ primitive-type ] "union" [ identifier ] "{" member-declaration-list "}"
                | "union" identifier

(* MEMBER DECLARATIONS (shared by class and union): *)

member-declaration-list = class-declaration+

class-declaration = specifier-qualifier-list class-declarator-list ";"

specifier-qualifier-list = type-specifier
                         | type-qualifier specifier-qualifier-list

class-declarator-list = member-declarator { "," member-declarator } [ "," ]

member-declarator = declarator [ ":" constant-expression ]
                  | ":" constant-expression

(* ENUM SPECIFIERS: *)

(*
  The primitive-type prefix selects the underlying integer type.
  It is only permitted when a body follows; "primitive-type enum name" without
  braces is a syntax error.
*)
enum-specifier = [ primitive-type ] "enum" [ identifier ] "{" enumerator-list "}"
               | "enum" identifier

enumerator-list = enumerator { "," enumerator } [ "," ]

enumerator = identifier [ "=" constant-expression ]

(* DECLARATORS: *)

declarator = [ pointer ] direct-declarator

pointer = "*" [ type-qualifier-list ] [ pointer ]

direct-declarator = identifier
                  | "(" declarator ")"
                  | direct-declarator "[" "]"
                  | direct-declarator "[" constant-expression "]"
                  | direct-declarator "(" ")"
                  | direct-declarator "(" parameter-type-list ")"

abstract-declarator = pointer [ direct-abstract-declarator ]
                    | direct-abstract-declarator

direct-abstract-declarator = "(" abstract-declarator ")"
                           | [ direct-abstract-declarator ] "[" "]"
                           | [ direct-abstract-declarator ] "[" constant-expression "]"
                           | [ direct-abstract-declarator ] "(" ")"
                           | [ direct-abstract-declarator ] "(" parameter-type-list ")"

(* PARAMETERS: *)

parameter-type-list = parameter-list [ "," "..." ]

parameter-list = parameter-declaration { "," parameter-declaration }

parameter-declaration = declaration-specifier-list
                      | declaration-specifier-list declarator [ "=" assignment-expression ]
                      | declaration-specifier-list abstract-declarator

type-name = specifier-qualifier-list [ abstract-declarator ]

(* INITIALIZERS: *)

init-declarator-list = init-declarator { "," init-declarator }

init-declarator = declarator [ "=" initializer ]

initializer = assignment-expression
            | "{" initializer-list [ "," ] "}"

initializer-list = initializer-item { "," initializer-item } [ "," ]

initializer-item = initializer
                 | designated-initializer

designated-initializer = "." identifier "=" initializer
                       | "[" constant-expression "]" "=" initializer

(* STATEMENTS: *)

statement = labeled-statement
          | expression-statement
          | print-statement
          | compound-statement
          | selection-statement
          | iteration-statement
          | jump-statement

compound-statement = "{" "}"
                   | "{" stmt-or-decl-list "}"

(* A compound statement body may freely interleave declarations, statements, and local functions. *)
stmt-or-decl-list = ( function-definition | declaration | statement )+

labeled-statement = identifier ":" statement
                  | "case" constant-expression ":" statement
                  | "case" constant-expression "..." constant-expression ":" statement
                  | "default" ":" statement

expression-statement = ";"
                     | expression ";"

(*
  A bare string literal followed by optional arguments is a print statement.
  This is a HolyC-specific construct for formatted output.
*)
print-statement = string-literal ";"
                | string-literal "," argument-expression-list ";"

selection-statement = "if" "(" expression ")" statement
                    | "if" "(" expression ")" statement "else" statement
                    | "switch" "(" expression ")" statement

iteration-statement = "while" "(" expression ")" statement
                    | "do" statement "while" "(" expression ")" ";"
                    | "for" "(" for-init-opt ";" [ expression ] ";" [ expression ] ")" statement

(* The for-loop initializer may be a declaration, an expression, or absent. *)
for-init-opt = declaration-specifier-list init-declarator-list
             | expression
             | ε

jump-statement = "goto" identifier ";"
               | "break" ";"
               | "continue" ";"
               | "return" ";"
               | "return" expression ";"

(* EXPRESSIONS: *)

expression = assignment-expression { "," assignment-expression }

assignment-expression = conditional-expression
                      | unary-expression assignment-operator assignment-expression

assignment-operator = "=" | "*=" | "/=" | "%=" | "+=" | "-="
                    | "<<=" | ">>=" | "&=" | "^=" | "|="

conditional-expression = logical-or-expression [ "?" expression ":" conditional-expression ]

constant-expression = conditional-expression

logical-or-expression = logical-and-expression { "||" logical-and-expression }

logical-and-expression = inclusive-or-expression { "&&" inclusive-or-expression }

inclusive-or-expression = exclusive-or-expression { "|" exclusive-or-expression }

exclusive-or-expression = and-expression { "^" and-expression }

and-expression = equality-expression { "&" equality-expression }

equality-expression = relational-expression { ( "==" | "!=" ) relational-expression }

relational-expression = shift-expression { ( "<" | ">" | "<=" | ">=" ) shift-expression }

shift-expression = additive-expression { ( "<<" | ">>" ) additive-expression }

additive-expression = multiplicative-expression { ( "+" | "-" ) multiplicative-expression }

multiplicative-expression = cast-expression { ( "*" | "/" | "%" ) cast-expression }

(* Casts in EnlightenedC are prefix: "(type) expr", not postfix as in original HolyC. *)
cast-expression = unary-expression
                | "(" type-name ")" cast-expression

unary-expression = postfix-expression
                 | "++" unary-expression
                 | "--" unary-expression
                 | unary-operator unary-expression
                 | "sizeof" unary-expression
                 | "sizeof" "(" type-name ")"

unary-operator = "&" | "*" | "+" | "-" | "~" | "!"

postfix-expression = primary-expression { "[" expression "]"
                                        | "(" ")"
                                        | "(" argument-expression-list ")"
                                        | "." identifier
                                        | "->" identifier
                                        | "++"
                                        | "--" }

primary-expression = identifier
                   | constant
                   | string-literal
                   | "(" expression ")"

argument-expression-list = assignment-expression { "," assignment-expression }

(* Adjacent string literals are concatenated. *)
string-literal = string-constant { string-constant }

constant = integer-constant
         | character-constant
         | floating-constant
         | "true"
         | "false"

(* TERMINALS (described with regular expressions): *)

identifier = "[_a-zA-Z]\w*"

integer-constant = "0x" [0-9A-Fa-f]+ | "0" [0-7]* | [1-9][0-9]*

floating-constant = [0-9]+ ( "." [0-9]* )? ( [eE] [-+]? [0-9]+ )?

character-constant = "'.{1,8}'"

string-constant = "\".*\""
